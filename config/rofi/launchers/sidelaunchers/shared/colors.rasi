/*--------Importing colors-----*/
@import '~/.config/rofi/colors/colors.rasi'

/*--------Color definitions------------*/
* {
       background:       @surface;
       background-alt:   @surface-container-highest;
       background-alpha: @surface-alpha;
       foreground:       @on-surface;
       border-color:     @tertiary;
       selected:         @primary-fixed;
       selected-text:    @surface;
       active:           @tertiary;
       urgent:           @error;
}
